---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 8);
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				margin: 4rem 0 3rem;
			}
			.hero p {
				max-width: 640px;
				font-size: 1.125rem;
				line-height: 1.8;
			}
			.actions {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
				margin-top: 1.5rem;
			}
			.actions a {
				font-weight: 700;
			}
			.post-list {
				display: grid;
				gap: 1.25rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-list a {
				display: block;
				padding: 1rem 0;
				text-decoration: none;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-list h3 {
				margin: 0 0 0.35rem;
				color: rgb(var(--black));
			}
			.post-list p {
				margin: 0;
				color: rgb(var(--gray));
			}
			.post-list a:hover h3 {
				color: rgb(var(--accent));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Changken Blog</h1>
				<p>
					Cloud certification notes, software development, crypto, hardware, and career reflections.
					This site is the Astro version of my old WordPress blog.
				</p>
				<div class="actions">
					<a href="/blog/">Read all posts</a>
					<a href="/about/">About</a>
				</div>
			</section>
			<section>
				<h2>Latest Posts</h2>
				<ul class="post-list">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h3>{post.data.title}</h3>
									<p>
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
